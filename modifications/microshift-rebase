#!/bin/bash

# To rebase against nightlies, define MICROSHIFT_PAYLOAD_X86_64 and MICROSHIFT_PAYLOAD_AARCH64
#   as the pullspecs of x86_64 and aarch64 release payloads.
# To rebase against a named release, define RELEASE_NAME.
# To not rebase at all, define MICROSHIFT_NO_REBASE=1
#
# Auth file can be provided via:
#   --registry-config <path>  (preferred, CLI flag)
#   REGISTRY_AUTH_FILE env var (fallback)

set -e

RELEASE_REPO="${RELEASE_REPO:-quay.io/openshift-release-dev/ocp-release}"

fail() {
    msg=$1
    >&2 echo "$msg"
    exit 1
}

# Parse command line arguments
REGISTRY_CONFIG_CLI=""
while [[ $# -gt 0 ]]; do
    case $1 in
        --registry-config=*)
            REGISTRY_CONFIG_CLI="${1#*=}"
            shift
            ;;
        *)
            fail "Unknown argument: $1"
            ;;
    esac
done

# If MICROSHIFT_NO_REBASE is set and non-zero, stop execution here
if [ -n "$MICROSHIFT_NO_REBASE" ] && [ "$MICROSHIFT_NO_REBASE" -ne 0 ] ; then
    echo "MICROSHIFT_NO_REBASE is defined. Rebase will not be run."
    exit 0
fi

# Determine which rebase command to run
if [ -n "$RELEASE_NAME" ]; then
    REBASE_CMD="./scripts/auto-rebase/rebase.sh to $RELEASE_REPO:$RELEASE_NAME-x86_64 $RELEASE_REPO:$RELEASE_NAME-aarch64"
elif [ -n "$MICROSHIFT_PAYLOAD_X86_64" ] && [ -n "$MICROSHIFT_PAYLOAD_AARCH64" ]; then
    REBASE_CMD="./scripts/auto-rebase/rebase.sh to $MICROSHIFT_PAYLOAD_X86_64 $MICROSHIFT_PAYLOAD_AARCH64"
else
    fail "Environment variable RELEASE_NAME is not set."
fi

# Validate that --registry-config was provided
if [ -z "$REGISTRY_CONFIG_CLI" ]; then
    fail "Missing required argument: --registry-config <path>"
fi

if [ ! -f "$REGISTRY_CONFIG_CLI" ]; then
    fail "Auth file not found at: $REGISTRY_CONFIG_CLI"
fi

HOST_AUTH_FILE="$REGISTRY_CONFIG_CLI"
echo "Using registry auth file: $HOST_AUTH_FILE"

# Build the podman image
DIR=$(dirname $(readlink -f $0))
PODMAN_BUILD_CMD="podman build  -t microshift-rebase:$BREW_TAG $DIR"
echo $PODMAN_BUILD_CMD
eval $PODMAN_BUILD_CMD
podman image prune -f  # clean up unused images

# Run the podman container
PODMAN_RUN_CMD="podman run --rm \
-e RELEASE_NAME \
-e MICROSHIFT_PAYLOAD_X86_64 \
-e MICROSHIFT_PAYLOAD_AARCH64 \
-e REGISTRY_AUTH_FILE=/workdir/microshift/auth.json \
-v $HOST_AUTH_FILE:/workdir/microshift/auth.json:ro,z \
-v $PWD:/workdir/microshift:z \
-w /workdir/microshift \
microshift-rebase:$BREW_TAG \
$REBASE_CMD"
echo $PODMAN_RUN_CMD
eval $PODMAN_RUN_CMD
